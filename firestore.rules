rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if user is admin (by querying users collection or checking metadata)
    // Note: Since rules are evaluated on each write, a simpler/flexible admin check:
    // Either their email is the master admin email 'gerlianemagalhaes79@gmail.com' OR they have the admin role.
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'gerlianemagalhaes79@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Allow creation for self during registration, or any write by admin
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // License keys collection
    match /licenseKeys/{keyId} {
      // Anyone authenticated can read/query a key to check validity
      allow read: if isAuthenticated();
      // Only admin can write/create keys
      allow write: if isAdmin();
    }
  }
}
